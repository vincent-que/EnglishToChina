{
  "name": "english-to-china-translator",
  "version": "1.0.0",
  "description": "英文转中文桌面翻译工具：上传英文 PDF/Word，输出尽量保持原排版的中文翻译文档。",
  "main": "dist/main/main/index.js",
  "author": "",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\"",
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json && electron .",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "python:prepare-embedded": "powershell -ExecutionPolicy Bypass -File scripts/prepare-python-embedded.ps1",
    "typecheck": "tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.main.json",
    "lint": "eslint src/ --ext .ts,.tsx"
  },
  "dependencies": {
    "lucide-react": "^0.460.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "electron-packager": "^17.1.2",
    "eslint": "^9.14.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "build": {
    "appId": "com.translator.english-to-china",
    "productName": "英文转中文翻译工具",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "python/**/*",
      "resources/**/*",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "python",
        "to": "python"
      },
      {
        "from": "resources",
        "to": "resources"
      },
      {
        "from": "python-embedded",
        "to": "python-embedded",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
